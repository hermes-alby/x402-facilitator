# URL of the x402 Lightning facilitator
FACILITATOR_URL=http://localhost:3000

# Merchant's Nostr Wallet Connect URL — invoices are created against this wallet.
# Each merchant running this app server supplies their own NWC connection string.
# Get this from your NWC-compatible wallet (Alby, Mutiny, etc.)
# Format: nostr+walletconnect://<pubkey>?relay=<relay_url>&secret=<secret>
MERCHANT_NWC_URL=nostr+walletconnect://

# HTTP server port
PORT=4000
